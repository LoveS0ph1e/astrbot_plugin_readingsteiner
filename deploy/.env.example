# EverOS 配置模板 —— 复制为 .env 并填入你的 key（.env 已 gitignore，勿提交）
#   cp deploy/.env.example deploy/.env
#
# 下面是本项目实际验证跑通的三家混搭组合（DeepSeek + OpenRouter + DashScope）。
# 任何 OpenAI 协议兼容端点都可替换；也可用 DashScope 一个 key 全包，详见 EverOS 官方 .env.example。

# ─── LLM（对话提取，记忆质量的核心）───
# deepseek-v4-pro = 思考模式（提取质量最佳）；deepseek-v4-flash = 更快更省的非思考。
# ⚠️ 旧名 deepseek-chat / deepseek-reasoner 于 2026-07-24 弃用，已分别等价 flash 非思考 / pro 思考。
EVEROS_LLM__MODEL=deepseek-v4-pro
EVEROS_LLM__API_KEY=
EVEROS_LLM__BASE_URL=https://api.deepseek.com/v1

# ─── 多模态 LLM（图片/PDF/音频解析；纯文本场景可与 LLM 同 key）───
EVEROS_MULTIMODAL__MODEL=google/gemini-3-flash-preview
EVEROS_MULTIMODAL__API_KEY=
EVEROS_MULTIMODAL__BASE_URL=https://openrouter.ai/api/v1

# ─── Embedding（向量化，检索必需）───
EVEROS_EMBEDDING__MODEL=text-embedding-v4
EVEROS_EMBEDDING__API_KEY=
EVEROS_EMBEDDING__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ─── Rerank（重排，可选；留空则 hybrid 检索退化为纯向量，不影响基本可用）───
EVEROS_RERANK__MODEL=
EVEROS_RERANK__API_KEY=
EVEROS_RERANK__BASE_URL=

# ─── 运行时 ───
EVEROS_LOG_LEVEL=INFO
TZ=Asia/Shanghai
